# ----------------------------------------------------------------------
# Evolut — environment template
# Copy this to `.env.local` for local dev, or set in Vercel/host for prod.
# ----------------------------------------------------------------------

# ===== Public site =====================================================
# Canonical URL — used by metadataBase, sitemap, robots, structured data.
# Override per environment (preview, prod, custom domain) on the host.
NEXT_PUBLIC_SITE_URL=https://evolutecomsolutions.com

# ===== Supabase ========================================================
# Project URL (https://<project-ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
# Anon key — safe to expose, used for any read-only client work
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER-ONLY. Bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ===== Resend ==========================================================
# API key from https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender — must match a domain you've verified in Resend
RESEND_FROM_EMAIL="Evolut <hello@evolutecomsolutions.com>"
# Where contact submissions get notified
CONTACT_NOTIFY_EMAIL=support@evolutecomsolutions.com

# ===== Admin panel =====================================================
# Plain password gate for /admin. Use a long random string in production.
ADMIN_PASSWORD=
# Cookie secret used to sign the admin session cookie (32+ random chars)
ADMIN_COOKIE_SECRET=

# ===== Search engine verification ======================================
# Google Search Console — content value from the meta tag (NOT full tag).
# Get it at https://search.google.com/search-console
GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools — optional
BING_SITE_VERIFICATION=
# Yandex Webmaster — optional
YANDEX_VERIFICATION=
